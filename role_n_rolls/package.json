{
  "name": "role-n-rolls",
  "private": true,
  "version": "0.1.0",
  "description": "D&D companion app — MJ screen, character sheets, lore builder, maps",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "dev": "npm-run-all --parallel dev:client dev:server",
    "build": "npm --workspace client run build",
    "lint": "npm --workspace client run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
